{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "noEmit": true,
    "esModuleInterop": true,
    "paths": { "@/*": ["./*"] }
  },
  "include": ["app/**/*", "lib/**/*", "scripts/**/*"]
}
