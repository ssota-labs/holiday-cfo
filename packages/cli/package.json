{
  "name": "@holiday/cli",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "bin": {
    "holiday": "./dist/main.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "bundle": "tsup",
    "bundle:check": "tsup && git diff --exit-code -- ../../plugin/bin/holiday.mjs"
  },
  "dependencies": {
    "@holiday/core": "workspace:*",
    "@holiday/store-sqlite": "workspace:*",
    "commander": "^13.0.0"
  }
}
