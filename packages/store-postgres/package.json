{
  "name": "@holiday-cfo/store-postgres",
  "version": "0.4.4",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run migrations:inline && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "migrations:generate": "drizzle-kit generate",
    "migrations:inline": "node --experimental-strip-types scripts/inline-migrations.ts",
    "migrations:build": "pnpm run migrations:generate && pnpm run migrations:inline"
  },
  "dependencies": {
    "@holiday-cfo/core": "workspace:*",
    "@holiday-cfo/store-sql": "workspace:*"
  },
  "peerDependencies": {
    "postgres": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "postgres": {
      "optional": true
    }
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@holiday-cfo/store-testkit": "workspace:*",
    "drizzle-kit": "1.0.0-rc.4",
    "drizzle-orm": "1.0.0-rc.4",
    "postgres": "^3.4.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ssota-labs/holiday-cfo.git",
    "directory": "packages/store-postgres"
  }
}
