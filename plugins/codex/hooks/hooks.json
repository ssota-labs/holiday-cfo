{
  "description": "SessionStart: refresh project document skills and ensure status.md exists (soft-fail; ledger cwd only). Codex may require trusting plugin hooks before this runs.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/update-document-skills.sh\"",
            "timeout": 120,
            "statusMessage": "Updating project document skills"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/ensure-status-md.sh\"",
            "timeout": 120,
            "statusMessage": "Ensuring ledger status.md"
          }
        ]
      }
    ]
  }
}
