{
  "name": "@holiday-cfo/docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build && pnpm run check:rules && pnpm run check:planning",
    "start": "next start",
    "test": "node --test --experimental-strip-types scripts/*.test.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "check:rules": "node --experimental-strip-types scripts/check-rule-links.ts",
    "check:planning": "node --experimental-strip-types scripts/check-planning.ts"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.11.5",
    "fumadocs-mdx": "^15.2.0",
    "fumadocs-typescript": "^5.3.0",
    "fumadocs-ui": "^16.11.5",
    "lucide-react": "^0.469.0",
    "next": "^16.1.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.3"
  }
}
